            self.rows = [("Prod", DummyCombo(""))]
            self.doc_vars = {"Prod": DummyVar("Bestelbon")}
            self.doc_num_vars = {"Prod": DummyVar("")}
            self._update_preview_from_any_combo = lambda: None


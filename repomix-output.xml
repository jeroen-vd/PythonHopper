            self.app.update_footer_note(note)
            self._reload_footer_note()

        def _reset_footer_note(self) -> None:
            self.app.update_footer_note(DEFAULT_FOOTER_NOTE)
            self._reload_footer_note()

        def _reload_en1090_note(self) -> None:
